# Backporcher Multi-Agent Configuration
# Copy to .env and fill in values

# Claude Code (uses mounted credentials, no API key needed here)
# ANTHROPIC_API_KEY is passed via container volume mount

# Kimi Code API Key (from https://platform.moonshot.cn)
KIMI_API_KEY=

# OpenAI Codex API Key
CODEX_API_KEY=

# Which agents are enabled (comma-separated: claude,kimi,codex)
BACKPORCHER_ENABLED_AGENTS=claude

# Default agent for new tasks
BACKPORCHER_DEFAULT_AGENT=claude

# Fallback chain when an agent fails (comma-separated, in priority order)
BACKPORCHER_FALLBACK_CHAIN=claude,kimi,codex
